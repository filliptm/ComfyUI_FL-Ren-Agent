# === Backend Auto-Start ===
# Automatically start backend server when ComfyUI loads
AUTO_START_BACKEND=true

# Automatically restart backend if it crashes
AUTO_RESTART_BACKEND=true

# Log backend output to file (backend/logs/server.log)
LOG_BACKEND_TO_FILE=true

# === LLM Provider Configuration ===
# Choose your provider: openai, anthropic, gemini, or openrouter
LLM_PROVIDER=gemini

# Model name (OPTIONAL - if not set, uses intelligent provider defaults)
# Leave blank to use the recommended default for your provider:
#   - OpenAI: gpt-4-turbo-preview
#   - Anthropic: claude-3-5-sonnet-20241022
#   - Gemini: gemini-2.0-flash-exp
#   - OpenRouter: deepseek/deepseek-chat
#
# Override only if you need a specific model:
LLM_MODEL=
#
# Manual override examples:
#   OpenAI: gpt-4, gpt-3.5-turbo, o1-preview
#   Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229
#   Gemini: gemini-2.0-flash-exp, gemini-1.5-pro, models/gemini-pro
#   OpenRouter: anthropic/claude-3.5-sonnet, google/gemini-pro-1.5

# Model parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=32000

# === API Keys ===
# Add the API key for your chosen provider(s)
# Only the key for your active LLM_PROVIDER is required
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-api-key-here
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# === WebSocket Settings ===
WS_HOST=0.0.0.0
WS_PORT=8000
WS_HEARTBEAT_INTERVAL=30
WS_SESSION_TIMEOUT=300
WS_MAX_RECONNECT_ATTEMPTS=5

# === Connection Limits ===
MAX_CONNECTIONS_PER_IP=10
MAX_MESSAGE_SIZE=1000000

# === Tool Execution ===
TOOL_TIMEOUT=30000
MAX_TOOL_RETRIES=3

# === ComfyUI Server Configuration ===
COMFYUI_SERVER_URL=http://127.0.0.1:8188
COMFYUI_API_TIMEOUT=10

# === FL_Agent API Server Configuration ===
# This is perfect for using Ren Go app

# For local development
PUBLIC_URL=http://127.0.0.1:8000

# For ngrok (when running)
PUBLIC_URL=https://your-ngrok-url.ngrok.io

# === Conversation ===
CONVERSATION_MAX_HISTORY=50

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json
