# === Backend Auto-Start ===
# Automatically start backend server when ComfyUI loads
AUTO_START_BACKEND=true

# Automatically restart backend if it crashes
AUTO_RESTART_BACKEND=true

# Log backend output to file (backend/logs/server.log)
LOG_BACKEND_TO_FILE=true

# === LLM Provider Configuration ===
# Choose your provider: openai, anthropic, or gemini
LLM_PROVIDER=openai

# Model name for your chosen provider
LLM_MODEL=gpt-4-turbo-preview
# Other options:
#   OpenAI: gpt-4, gpt-3.5-turbo
#   Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
#   Google: gemini-pro, gemini-pro-vision

# Model parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000

# === API Keys ===
# Add the API key for your chosen provider
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-api-key-here

# === WebSocket Settings ===
WS_HOST=0.0.0.0
WS_PORT=8000
WS_HEARTBEAT_INTERVAL=30
WS_SESSION_TIMEOUT=300
WS_MAX_RECONNECT_ATTEMPTS=5

# === Connection Limits ===
MAX_CONNECTIONS_PER_IP=10
MAX_MESSAGE_SIZE=1000000

# === Tool Execution ===
TOOL_TIMEOUT=30000
MAX_TOOL_RETRIES=3

# === ComfyUI Server Configuration ===
COMFYUI_SERVER_URL=http://127.0.0.1:8188
COMFYUI_API_TIMEOUT=10

# === Conversation ===
CONVERSATION_MAX_HISTORY=50

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json
